  },
  "hyprland/language": {
      "format": "{}",
      "format-en": "EN",
      "format-ru": "RU",
      "format-he": "HE"
  },
  "custom/vpn": {
      "format": "{}",
      "exec": "~/.config/waybar/scripts/vpn-status.sh",
      "return-type": "json",
      "interval": 2,
      "on-click": "~/.config/waybar/scripts/vpn-menu.sh",
      "on-click-right": "nm-connection-editor"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
        "activated": "´ü« ",

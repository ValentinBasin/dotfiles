      "format-ethernet": "ˇ░łÇ  {ipaddr}",
      "format-linked": "{ifname} (No IP) ´×ľ",
      "format-disconnected": "ÔÜá Disconnected",
      "on-click": "nm-connection-editor"
  },
  "bluetooth": {
      "format": "´Őö {status}",
      "format-disabled": "",
      "format-connected": "´Őö {num_connections}",
      "on-click": "blueman-manager"
  },
  "custom/power": {
      "format": "ÔĆ╗",
      "tooltip": false,

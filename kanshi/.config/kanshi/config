### Profiles ###

profile laptop {
    output $LAPTOP enable position 0,0 scale 1.25
}

profile home_1 {
    output $HOME_1 enable position 0,0
    output $LAPTOP enable position 1920,0 scale 1.5
}

profile speedata_1 {
    output $SPEEDATA_1 enable position 0,0
    output $SPEEDATA_2 enable position 1920,0
    output $LAPTOP enable position 3840,0 scale 1.25
}

profile speedata_2 {
    output $SPEEDATA_3 enable position 0,0
    output $SPEEDATA_4 enable position 1920,0
    output $LAPTOP enable position 3840,0 scale 1.25
}

profile speedata_3 {
    output $SPEEDATA_5 enable position 0,0
    output $SPEEDATA_6 enable position 1920,0
    output $LAPTOP enable position 3840,0 scale 1.25
}

profile speedata_7 {
    output $SPEEDATA_13 enable position 0,0
    output $SPEEDATA_14 enable position 1920,0
    output $LAPTOP enable position 3840,0 scale 1.25
}

profile sequans_1 {
    output $SEQUANS_1 enable position 0,0
    output $SEQUANS_2 enable position 1920,0
    output $LAPTOP enable position 3840,0 scale 1.25
}

